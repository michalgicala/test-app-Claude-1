# Environment variables for the Python scraper (GitHub Actions)
# Copy this file to .env for local testing. Never commit .env.
#
# Email is handled by Google Apps Script — no Gmail credentials needed here.

# Google Sheets service account credentials (full JSON content, one line)
GOOGLE_SHEETS_CREDENTIALS_JSON='{...}'

# Spreadsheet ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
GOOGLE_SHEET_ID=your_sheet_id_here

# Free Gemini API key from https://aistudio.google.com/apikey
# Optional — if omitted, AI descriptions are skipped
GEMINI_API_KEY=your_gemini_api_key_here
