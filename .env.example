# Environment variables required to run book_discovery
# Copy this file to .env and fill in your values.
# Never commit the actual .env file.

# Google Sheets API service account credentials (full JSON content, one line)
GOOGLE_SHEETS_CREDENTIALS_JSON='{...}'

# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
GOOGLE_SHEET_ID=your_sheet_id_here

# Gmail address used to send the digest emails
GMAIL_USER=yourname@gmail.com

# 16-character App Password (Google Account → Security → App Passwords)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Email address that receives the digest (can be same as GMAIL_USER)
RECIPIENT_EMAIL=yourname@gmail.com

# Free Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
